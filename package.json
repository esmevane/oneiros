{
  "name": "oneiros",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "tokens": "pnpm --filter @oneiros/tokens run build",
    "format": "prettier --write \"**/*.{ts,tsx,astro,mdx,json,yaml,yml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,mdx,json,yaml,yml,css}\"",
    "lint": "oxlint",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck && pnpm --filter @oneiros/dashboard exec astro check && pnpm --filter @oneiros/docs exec astro check",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "oxlint": "^1.66.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1"
  }
}
